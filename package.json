{
  "name": "djs-bot-template",
  "version": "1.1.2",
  "description": "A simple discord.js bot template written in nodejs",
  "main": "lib/bot.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "nodemon .",
    "start": "node .",
    "setup": "node ./lib/utils/setup.js"
  },
  "keywords": [
    "bot",
    "discordjs",
    "nodejs",
    "framework"
  ],
  "author": "NovaLynxie",
  "license": "ISC",
  "dependencies": {
    "common-tags": "^1.8.2",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "toml": "^3.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "nodemonConfig": {
    "delay": 5000,
    "ignore": [
      "lib/commands/*",
      "lib/events/*",
      "logs/*"
    ]
  }
}
